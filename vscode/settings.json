{
  "git.autofetch": true,
  "github.copilot.nextEditSuggestions.enabled": true,

  // === テーマ ===
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "catppuccin-mocha",

  // === フォント ===
  "editor.fontFamily": "'UDEV Gothic 35NFLG', 'JetBrains Mono', Consolas, monospace",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "terminal.integrated.fontFamily": "'UDEV Gothic 35NFLG', 'JetBrainsMono Nerd Font', monospace",
  "terminal.integrated.fontSize": 13,

  // === スムーズアニメーション ===
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "workbench.list.smoothScrolling": true,
  "terminal.integrated.smoothScrolling": true,

  // === ミニマルUI ===
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.renderLineHighlight": "gutter",
  "breadcrumbs.enabled": false,
  "workbench.activityBar.location": "top",
  "window.commandCenter": true,
  "editor.stickyScroll.enabled": true,

  // === ブラケットペア（内蔵機能） ===
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",

  // === ターミナル見た目 ===
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorStyleInactive": "outline",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.gpuAcceleration": "on",

  // === 透け感 (Glassit) ===
  "glassit.alpha": 230,

  "workbench.colorCustomizations": {
    "[Catppuccin Mocha]": {
      "editor.background": "#1e1e2ed0",
      "sideBar.background": "#181825c8",
      "sideBarSectionHeader.background": "#181825c8",
      "activityBar.background": "#11111bc8",
      "titleBar.activeBackground": "#11111bc0",
      "titleBar.inactiveBackground": "#11111bb0",
      "tab.activeBackground": "#1e1e2ed0",
      "tab.inactiveBackground": "#181825c0",
      "editorGroupHeader.tabsBackground": "#181825c0",
      "panel.background": "#1e1e2ec8",
      "statusBar.background": "#11111bc0",
      "statusBar.noFolderBackground": "#11111bc0",
      "statusBar.debuggingBackground": "#11111bc0",
      "terminal.background": "#1e1e2ec0",
      "list.activeSelectionBackground": "#45475a80",
      "list.hoverBackground": "#45475a60",
      "editorWidget.background": "#181825e0",
      "quickInput.background": "#181825e8",
      "quickInputList.focusBackground": "#45475a80"
    }
  }
}
