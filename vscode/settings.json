{
  // === テーマ・アイコン ===
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "catppuccin-mocha",
  "catppuccin-icons.hidesExplorerArrows": true,

  // === ウィンドウ ===
  "window.zoomLevel": 2,
  "window.titleBarStyle": "custom",
  "window.customTitleBarVisibility": "never",
  "window.commandCenter": true,
  "window.menuBarVisibility": "toggle",

  // === ワークベンチ UI ===
  "workbench.activityBar.location": "hidden",
  "workbench.editor.showTabs": "single",
  "workbench.statusBar.visible": false,
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "workbench.list.smoothScrolling": true,
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.tree.indent": 10,

  // === エクスプローラー ===
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.decorations.badges": false,
  "breadcrumbs.enabled": false,

  // === エディター表示 ===
  "editor.lineNumbers": "relative",
  "editor.lineHeight": 2,
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.renderLineHighlight": "gutter",
  "editor.stickyScroll.enabled": true,
  "editor.colorDecorators": false,

  // === エディター動作 ===
  "editor.tabSize": 2,
  "editor.detectIndentation": false,

  // === フォント ===
  "editor.fontFamily": "'UDEV Gothic 35NFLG', 'JetBrains Mono', Consolas, monospace",
  "editor.fontSize": 13,
  "editor.fontLigatures": true,

  // === アニメーション ===
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,

  // === ブラケットペア ===
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",

  // === ファイル ===
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // === Git / SCM ===
  "git.decorations.enabled": false,
  "scm.diffDecorations": "all",

  // === ターミナル ===
  "terminal.integrated.fontFamily": "'UDEV Gothic 35NFLG', 'JetBrainsMono Nerd Font', monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorStyleInactive": "outline",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.smoothScrolling": true,
  "workbench.panel.showLabels": false,

  // === 拡張機能 ===
  "color-highlight.markerType": "dot-before",
  "claudeCode.preferredLocation": "panel",
}
